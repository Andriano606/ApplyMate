RAILS_MASTER_KEY=$(cat config/credentials/staging.key)
KAMAL_REGISTRY_PASSWORD=$(RAILS_ENV=staging bin/rails credentials:fetch kamal.registry_password)
POSTGRES_PASSWORD=$(RAILS_ENV=staging bin/rails credentials:fetch kamal.postgres_password)
APPLY_MATE_DATABASE_PASSWORD=$POSTGRES_PASSWORD
MINIO_ROOT_USER=$(RAILS_ENV=staging bin/rails credentials:fetch minio.access_key_id)
MINIO_ROOT_PASSWORD=$(RAILS_ENV=staging bin/rails credentials:fetch minio.secret_access_key)
MINIO_ACCESS_KEY_ID=$MINIO_ROOT_USER
MINIO_SECRET_ACCESS_KEY=$MINIO_ROOT_PASSWORD
