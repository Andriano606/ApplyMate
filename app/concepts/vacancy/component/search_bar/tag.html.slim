span.inline-flex.items-center.gap-1.5.px-2.py-1.rounded-full.text-xs.font-medium [
  class='bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-200'
  ]
  = @label
  = boolean_link form: @form,
          name: @name,
          index: @index,
          label_class: 'flex items-center justify-center cursor-pointer w-3 h-3 m-0 p-0 leading-none \
            text-gray-400 hover:text-red-500 transition-colors duration-200 peer-checked:text-red-700',
          icon: icon(:cross, size: 3),
          data: { action: 'change->turbo-form#update' }
