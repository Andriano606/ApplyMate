<div class="flex flex-col items-center justify-center min-h-[60vh]">
  <h1 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">
    <%= I18n.t('payments.redirecting', default: 'Redirecting to payment gateway...') %>
  </h1>
  <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>

  <form action="<%= Rails.env.development? ? dev_wayforpay_mock_path : 'https://secure.wayforpay.com/pay' %>" method="post" id="wayforpay-form" class="hidden" data-turbo="false">
    <% @params.each do |key, value| %>
      <% if value.is_a?(Array) %>
        <% value.each do |v| %>
          <input type="hidden" name="<%= key %>[]" value="<%= v %>">
        <% end %>
      <% else %>
        <input type="hidden" name="<%= key %>" value="<%= value %>">
      <% end %>
    <% end %>
    <button type="submit" class="mt-4 px-6 py-2 bg-blue-600 text-white rounded">
      <%= I18n.t('payments.pay_now', default: 'Pay Now') %>
    </button>
  </form>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    document.getElementById('wayforpay-form').submit();
  });
</script>
